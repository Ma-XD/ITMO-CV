    "## §3. Импорты и проверка конфигурации\n",
    "Загружаем пути из `config.py` и проверяем доступность GPU."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "from pathlib import Path\n",
    "import torch\n",
    "import matplotlib.pyplot as plt\n",
    "from PIL import Image\n",
    "\n",
    "# Добавляем папку лабы в sys.path для импорта конфигов\n",
    "lab_dir = Path(\"lab5-DIF\").resolve() if not is_colab else Path(\"/content/ITMO-CV/lab5-DIF\")\n",
    "if str(lab_dir) not in sys.path:\n",
    "    sys.path.insert(0, str(lab_dir))\n",
    "\n",
    "from env_config import print_env, get_device\n",
    "from config import (\n",
    "    INSTANCE_DIR, CLASS_DIR, CHECKPOINT_DIR, FIGURE_DIR,\n",
    "    MODEL_ID, INSTANCE_PROMPT, CLASS_PROMPT, RESOLUTION\n",
    ")\n",
    "\n",
    "print_env()\n",
    "device = get_device()\n",
    "\n",
    "print(f\"\\nПапка с фото пользователя (Instance): {INSTANCE_DIR}\")\n",
    "print(f\"Папка с фото класса (Class): {CLASS_DIR}\")\n",
    "print(f\"Чекпоинты сохраняются в: {CHECKPOINT_DIR}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## §4. Загрузка базовой модели и Smoke-test\n",
    "Загружаем оригинальную модель Stable Diffusion v1.5 и проверяем её работоспособность до дообучения. Сгенерируем обычного кота."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from diffusers import StableDiffusionPipeline\n",
    "import torch\n",
    "\n",
    "# Загружаем пайплайн базовой модели\n",
    "pipeline = StableDiffusionPipeline.from_pretrained(\n",
    "    MODEL_ID,\n",
    "    torch_dtype=torch.float16 if device.type == \"cuda\" else torch.float32,\n",
    "    safety_checker=None  # Отключаем safety checker для ускорения и избежания ложных срабатываний\n",
    ")\n",
    "pipeline = pipeline.to(device)\n",
    "\n",
    "# Для ускорения инференса и экономии памяти\n",
    "if device.type == \"cuda\":\n",
    "    pipeline.enable_attention_slicing()\n",
    "\n",
    "print(\"✅ Базовая модель успешно загружена!\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Smoke-test: генерация тестового изображения\n",
    "prompt = \"a photo of a cat, high quality, highly detailed\"\n",
    "generator = torch.Generator(device=device).manual_seed(42)\n",
    "\n",
    "print(f\"Генерируем: '{prompt}'...\")\n",
    "test_image = pipeline(prompt, generator=generator, num_inference_steps=30).images[0]\n",
    "\n",
    "# Отрисовка результата\n",
    "plt.figure(figsize=(6, 6))\n",
    "plt.imshow(test_image)\n",
    "plt.axis('off')\n",
    "plt.title(\"Smoke-test: Базовая модель SD 1.5\")\n",
    "plt.show()"
   ]
  }
